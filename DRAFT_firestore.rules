rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (
        // Action: Update Profile
        incoming().diff(existing()).affectedKeys().hasOnly([
          'assistantName', 'wakeWord', 'userName', 'apiKey', 
          'vehicleInfo', 'inventory', 'onboardingComplete', 'email', 'updatedAt'
        ])
      );

      function isValidUser(data) {
        return data.keys().hasAll(['userName', 'onboardingComplete']) &&
               data.userName is string && data.userName.size() <= 100 &&
               data.onboardingComplete is bool &&
               (data.assistantName == null || (data.assistantName is string && data.assistantName.size() <= 100)) &&
               (data.email == null || (data.email is string && data.email.size() <= 200));
      }
    }

    // --- Tasks Collection ---
    match /tasks/{taskId} {
      // Secure list query
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(taskId) && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(taskId) && 
                      incoming().userId == request.auth.uid && 
                      isValidTask(incoming());
                      
      allow update: if isSignedIn() && isValidId(taskId) && 
                      existing().userId == request.auth.uid && 
                      incoming().userId == request.auth.uid && 
                      isValidTask(incoming()) && (
                        // Action: Edit Task
                        incoming().diff(existing()).affectedKeys().hasOnly(['text', 'completed', 'category', 'updatedAt'])
                      );
                      
      allow delete: if isSignedIn() && isValidId(taskId) && existing().userId == request.auth.uid;

      function isValidTask(data) {
        return data.keys().hasAll(['text', 'completed', 'userId']) &&
               data.text is string && data.text.size() <= 1000 &&
               data.completed is bool &&
               data.userId == request.auth.uid &&
               (data.category == null || (data.category is string && data.category.size() <= 50));
      }
    }

    // --- Chat Collection ---
    match /chats/{chatId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(chatId) && 
                      incoming().userId == request.auth.uid && 
                      isValidChat(incoming());

      function isValidChat(data) {
        return data.keys().hasAll(['role', 'text', 'userId']) &&
               data.role in ['user', 'model'] &&
               data.text is string && data.text.size() <= 10000 &&
               data.userId == request.auth.uid;
      }
    }
  }
}
